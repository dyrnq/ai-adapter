# AI Adapter Configuration
# This file sets environment variables for the proxy server.
# Command-line flags take priority over environment variables.

# Upstream API base URL (without trailing path)
UPSTREAM_BASE_URL=https://api.openai.com

# Upstream API format: anthropic, openai-chat, responses
UPSTREAM_FORMAT=openai-chat

# Upstream API key
UPSTREAM_API_KEY=sk-your-key-here

# Default model to use for requests
UPSTREAM_MODEL=

# Server host
HOST=0.0.0.0

# Server port
PORT=9090

# Log level: trace, debug, info, warn, error
RUST_LOG=info
